_keys\": [\n    \"client_error_ratio\",\n    \"error_ratio\",\n    \"rrt_max\",\n    \"rrt\",\n    \"node_memory_usage_rate\",\n    \"node_cpu_usage_rate\",\n    \"node_memory_MemAvailable_bytes\"\n  ],\n  \"hypotheses\": [\n    {\n      \"component\": \"adservice-0\",\n      \"reason\": \"Observed significant increase in 'error_ratio' and 'client_error_ratio' during fault time. These values spiked from normal p99=0.0 to fault p99=0.65.\",\n      \"evidence\": \"Significant p99 change ratio of 2.0 for both client_error_ratio and error_ratio.\"\n    },\n    {\n      \"component\": \"currencyservice-0\",\n      \"reason\": \"'rrt_max' showed notable p99 spike from 53741.52ms to 5595151.82ms during the fault interval.\",\n      \"evidence\": \"Median change ratio=0.1974 and p99 change ratio=1.9619.\"\n    },\n    {\n      \"component\": \"cartservice-1\",\n      \"reason\": \"'rrt_max' exhibited extreme delay with p99 surging from 80633.6ms to 4491768.66ms.\",\n      \"evidence\": \"Median change ratio=0.2002 and p99 change ratio=1.9295.\"\n    },\n    {\n      \"component\": \"frontend-2\",\n      \"reason\": \"Time metrics showed increased latency under 'rrt_max' escalating fault p99 from 426233.28 to 5813491.5.\",\n      \"evidence\": \"Median change ratio=0.0334 and p99 change ratio=1.7268.\"\n    },\n    {\n      \"component\": \"aiops-k8s-05\",\n      \"reason\": \"Node-level anomalies with 'node_memory_usage_rate' rising sharply and available memory dropping significantly.\",\n      \"evidence\": \"'node_memory_usage_rate' p99 increased from 39.76% to 73.67% and 'node_memory_MemAvailable_bytes' median dropped by 21.71%.\"\n    },\n    {\n      \"component\": \"emails-0\",\n      \"reason\": \"Email response times ('rrt_max') saw abnormal spikes from a normal p99 of 9513ms to fault p99 of 45655.86ms.\",\n      \"evidence\": \"increase conditions detected > base ranges noticed importance adj score breaches.\"\n    }\n  ]\n}\n```\n\n#### 数据总结\n- **显著异常对象清单**:\n  1.