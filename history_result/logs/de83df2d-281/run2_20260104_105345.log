ted_trace_keys\": [\n    \"latency_spike\",\n    \"timeout\",\n    \"connection_refused\",\n    \"frontend->AdService\",\n    \"checkoutservice->emailservice\",\n    \"checkoutservice->cartservice\",\n    \"checkoutservice->shippingservice\",\n    \"frontend->ProductCatalogService\",\n    \"cartservice->Redis\"\n  ],\n  \"hypotheses\": [\n    {\n      \"component\": \"AdService\",\n      \"reason\": \"AdService shows a high number of 'connection refused' errors during its transactions.\",\n      \"evidence\": {\n        \"status_code\": 14,\n        \"status_message\": \"connection error: desc = \\\"transport: Error while dialing dial tcp 10.233.8.174:9555: connect: connection refused\\\"\",\n        \"occurrences\": 2382\n      }\n    },\n    {\n      \"component\": \"cartservice->Redis\",\n      \"reason\": \"Redis shows an extreme spike in latency for operations initiated by CartService, increasing from an average of 1361ms to 11968ms.\",\n      \"evidence\": {\n        \"normal_avg_duration\": 1361.25,\n        \"anomaly_avg_duration\": 11968,\n        \"multiplier\": 8.79\n      }\n    },\n    {\n      \"component\": \"checkoutservice->shippingservice\",\n      \"reason\": \"Significant latency increases observed during calls from CheckoutService to ShippingService.\",\n      \"evidence\": [\n        {\n          \"operation\": \"ShippingService/ShipOrder\",\n          \"normal_avg_duration\": 220.88,\n          \"anomaly_avg_duration\": 774,\n          \"multiplier\": 3.50\n        },\n        {\n          \"operation\": \"ShippingService/GetQuote\",\n          \"normal_avg_duration\": 196.54,\n          \"anomaly_avg_duration\": 727,\n          \"multiplier\": 3.70\n        }\n      ]\n    },\n    {\n      \"component\": \"checkoutservice->cartservice\",\n      \"reason\": \"Calls from CheckoutService to CartService took significantly longer than usual. For example, the 'EmptyCart' operation increased from 2569ms to 32456ms.\",\n      \"evidence\": {\n        \"operation\": \"CartService/EmptyCart\",\n        \"normal_avg_duration\": 2569,\n        \"anomaly_avg_duration\": 32456.5,\n        \"multiplier\": 12.63\n      }\n    },\n    {\n      \"component\": \"checkoutservice->emailservice\",\n      \"reason\": \"Email send processes from CheckoutService show latency spikes (normal: 672ms; anomaly: 2087ms).\",\n      \"evidence\": {\n        \"operation\": \"EmailService/SendOrderConfirmation\",\n        \"normal_avg_duration\": 672.68,\n        \"anomaly_avg_duration\": 2087,\n        \"multiplier\": 3.10\n      }\n    },\n    {\n      \"component\": \"frontend->ProductCatalogService\",\n      \"reason\": \"Significant increase detected in ProductCatalogService latency (ListProducts operation: from 69ms to 207ms).\",\n      \"evidence\": {\n        \"operation\": \"ProductCatalogService/ListProducts\",\n        \"normal_avg_duration\": 69.93,\n        \"anomaly_avg_duration\": 207.13,\n        \"multiplier\": 2.96\n      }\n    }\n  ]\n}\n```"}
